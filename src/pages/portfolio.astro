---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PecaCard from "../components/portfolio/PecaCard.astro";
import GenerosLegenda from "../components/portfolio/GenerosLegenda.astro";
import { pecaDesbloqueada } from "../lib/portfolio";
import { generos as generosInfo } from "../lib/generos";

const pecas = (await getCollection("portfolio", (p) => p.id !== "juju-e-leleco")).sort((a, b) => {
	const desbloqueadaA = pecaDesbloqueada(a.id);
	const desbloqueadaB = pecaDesbloqueada(b.id);
	if (desbloqueadaA !== desbloqueadaB) return desbloqueadaA ? -1 : 1;
	if (a.id === "power-of-love") return -1;
	if (b.id === "power-of-love") return 1;
	const dataA = a.data.data ? new Date(a.data.data).getTime() : 0;
	const dataB = b.data.data ? new Date(b.data.data).getTime() : 0;
	return dataB - dataA;
});

const generos = Array.from(new Set(pecas.map((p) => p.data.genero).filter((g): g is string => Boolean(g)))).sort(
	(a, b) => a.localeCompare(b, "pt-BR")
);

const classificacoes = Array.from(
	new Set(pecas.map((p) => p.data.classificacao).filter((c): c is string => Boolean(c)))
).sort((a, b) => a.localeCompare(b, "pt-BR"));
---

<BaseLayout
	title="Portfólio - Adoração em Cena"
	description="Conheça as peças e apresentações do grupo de drama Adoração em Cena."
>
	<section class="portfolio-hero section">
		<div class="container">
			<p class="eyebrow reveal">Nosso trabalho</p>
			<h1 class="reveal">Portfólio</h1>
			<p class="portfolio-hero__intro reveal">
				Cada peça carrega uma mensagem, um propósito e muita entrega do grupo. Aqui reunimos fotos, vídeos
				e a história por trás de cada apresentação, e seguimos adicionando novas peças com o tempo.
			</p>
		</div>
	</section>

	{
		pecas.length === 0 ? (
			<section class="section em-breve">
				<div class="container em-breve__inner reveal">
					<span class="em-breve__icone" aria-hidden="true">
						✦
					</span>
					<h2>Em breve, novidades em cena</h2>
					<p>
						Estamos organizando o material das nossas peças para trazer tudo aqui: fotos, vídeos e
						descrições. Enquanto isso, acompanhe os bastidores no{" "}
						<a href="https://www.instagram.com/adoracaoemcena/" target="_blank" rel="noopener noreferrer">
							Instagram
						</a>
						.
					</p>
				</div>
			</section>
		) : (
			<section class="section">
				<div class="container">
					<div class="portfolio-controles reveal">
						<label class="portfolio-controles__campo">
							<span>Ordenar por</span>
							<select id="portfolio-ordenar">
								<option value="">Padrão</option>
								<option value="titulo">Ordem alfabética (A-Z)</option>
								<option value="genero">Gênero</option>
								<option value="duracao">Duração da peça</option>
							</select>
						</label>
						{
							generos.length > 0 && (
								<label class="portfolio-controles__campo">
									<span>
										Gênero
										<GenerosLegenda />
									</span>
									<select id="portfolio-filtro-genero">
										<option value="">Todos</option>
										{generos.map((genero) => (
											<option value={genero}>{genero}</option>
										))}
									</select>
								</label>
							)
						}
						{
							classificacoes.length > 0 && (
								<label class="portfolio-controles__campo">
									<span>Classificação</span>
									<select id="portfolio-filtro-classificacao">
										<option value="">Todas</option>
										{classificacoes.map((classificacao) => (
											<option value={classificacao}>{classificacao}</option>
										))}
									</select>
								</label>
							)
						}
					</div>

					<div class="portfolio-controles-mobile reveal">
						<button type="button" class="pcm-botao" data-abre="dialog-ordenar">
							<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
								<path d="M3 4h10M5 8h6M7 12h2" />
							</svg>
							<span>Ordenar</span>
						</button>
						{
							generos.length > 0 && (
								<button type="button" class="pcm-botao" data-abre="dialog-genero">
									<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
										<circle cx="8" cy="8" r="6" />
										<path
											d="M6 6c0-.9.7-1.4 1.6-1.4S9.2 5.1 9.2 6c0 1.1-1.6 1-1.6 2.3"
											stroke-linecap="round"
										/>
									</svg>
									<span>Gênero</span>
								</button>
							)
						}
						{
							classificacoes.length > 0 && (
								<button type="button" class="pcm-botao" data-abre="dialog-classificacao">
									<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3">
										<path d="M2 8l6-6h6v6l-6 6-6-6Z" />
										<circle cx="11" cy="5" r="0.8" fill="currentColor" stroke="none" />
									</svg>
									<span>Classificação</span>
								</button>
							)
						}
					</div>

					<dialog id="dialog-ordenar" class="pcm-dialog">
						<div class="pcm-dialog__head">
							<h3>Ordenar por</h3>
							<button type="button" class="pcm-fechar" data-fecha aria-label="Fechar">✕</button>
						</div>
						<div class="pcm-dialog__opcoes">
							<label>
								<input type="radio" name="pcm-ordenar" value="" checked /> Padrão
							</label>
							<label>
								<input type="radio" name="pcm-ordenar" value="titulo" /> Ordem alfabética (A-Z)
							</label>
							<label>
								<input type="radio" name="pcm-ordenar" value="genero" /> Gênero
							</label>
							<label>
								<input type="radio" name="pcm-ordenar" value="duracao" /> Duração da peça
							</label>
						</div>
					</dialog>

					{
						generos.length > 0 && (
							<dialog id="dialog-genero" class="pcm-dialog">
								<div class="pcm-dialog__head">
									<h3>Filtrar por gênero</h3>
									<button type="button" class="pcm-fechar" data-fecha aria-label="Fechar">✕</button>
								</div>
								<div class="pcm-dialog__opcoes">
									<label>
										<input type="radio" name="pcm-genero" value="" checked /> Todos
									</label>
									{generos.map((genero) => (
										<label class="pcm-dialog__opcao-genero">
											<input type="radio" name="pcm-genero" value={genero} />
											<span>
												<b>{genero}</b>
												{generosInfo[genero] && <small>{generosInfo[genero].definicao}</small>}
											</span>
										</label>
									))}
								</div>
							</dialog>
						)
					}

					{
						classificacoes.length > 0 && (
							<dialog id="dialog-classificacao" class="pcm-dialog">
								<div class="pcm-dialog__head">
									<h3>Filtrar por classificação</h3>
									<button type="button" class="pcm-fechar" data-fecha aria-label="Fechar">✕</button>
								</div>
								<div class="pcm-dialog__opcoes">
									<label>
										<input type="radio" name="pcm-classificacao" value="" checked /> Todas
									</label>
									{classificacoes.map((classificacao) => (
										<label>
											<input type="radio" name="pcm-classificacao" value={classificacao} /> {classificacao}
										</label>
									))}
								</div>
							</dialog>
						)
					}

					<div class="portfolio-grid">
						{pecas.map((peca) => (
							<PecaCard peca={peca} desbloqueada={pecaDesbloqueada(peca.id)} />
						))}
					</div>
				</div>
			</section>
		)
	}
</BaseLayout>

<style>
	.portfolio-hero {
		padding-bottom: var(--space-md);
		text-align: center;
	}

	.portfolio-hero__intro {
		color: var(--color-pearl-dim);
		max-width: 55ch;
		margin-inline: auto;
	}

	.em-breve {
		text-align: center;
	}

	.em-breve__inner {
		max-width: 40rem;
		margin-inline: auto;
		padding: var(--space-xl) var(--space-md);
		border: 1px dashed rgba(201, 166, 107, 0.3);
		border-radius: 16px;
	}

	.em-breve__icone {
		display: block;
		font-size: 2rem;
		color: var(--color-sand);
		margin-bottom: var(--space-sm);
	}

	.em-breve p {
		color: var(--color-pearl-dim);
	}

	.em-breve a {
		color: var(--color-crimson-bright);
		text-decoration: underline;
	}

	.portfolio-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(230px, 270px));
		justify-content: center;
		gap: var(--space-md);
	}

	.portfolio-controles {
		position: relative;
		z-index: 5;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-md);
		margin-bottom: var(--space-md);
	}

	.portfolio-controles__campo {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.85rem;
		color: var(--color-pearl-dim);
	}

	.portfolio-controles__campo > span {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
	}

	.portfolio-controles__campo select {
		padding: 0.45rem 0.8rem;
		border: 1px solid rgba(201, 166, 107, 0.35);
		border-radius: 8px;
		background: var(--color-obsidian-soft);
		color: var(--color-pearl);
		font-size: 0.85rem;
		cursor: pointer;
	}

	.portfolio-controles__campo select:focus-visible {
		outline: 1px solid var(--color-sand);
	}

	.portfolio-controles-mobile {
		display: none;
	}

	@media (max-width: 640px) {
		.portfolio-controles {
			display: none;
		}

		.portfolio-controles-mobile {
			display: flex;
			justify-content: center;
			gap: 0.6rem;
			margin-bottom: var(--space-md);
		}
	}

	.pcm-botao {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.3rem;
		width: 5.2rem;
		padding: 0.55rem 0.3rem;
		border-radius: 10px;
		border: 1px solid rgba(201, 166, 107, 0.25);
		background: var(--color-obsidian-soft);
		color: var(--color-pearl-dim);
		font-size: 0.68rem;
	}

	.pcm-botao svg {
		width: 16px;
		height: 16px;
	}

	.pcm-botao.is-ativo {
		border-color: var(--color-sand);
		color: var(--color-sand-soft);
	}

	.pcm-dialog {
		width: min(22rem, calc(100vw - 2.5rem));
		padding: 1.1rem;
		border: 1px solid rgba(201, 166, 107, 0.35);
		border-radius: 14px;
		background: var(--color-obsidian-soft);
		color: var(--color-pearl);
	}

	.pcm-dialog::backdrop {
		background: rgba(13, 11, 12, 0.75);
	}

	.pcm-dialog__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 0.8rem;
	}

	.pcm-dialog__head h3 {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 1.05rem;
		color: var(--color-pearl);
	}

	.pcm-fechar {
		width: 1.8rem;
		height: 1.8rem;
		border-radius: 50%;
		border: 1px solid rgba(242, 236, 228, 0.25);
		background: none;
		color: var(--color-pearl-dim);
		font-size: 0.8rem;
		cursor: pointer;
	}

	.pcm-dialog__opcoes {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}

	.pcm-dialog__opcoes label {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.55rem 0.4rem;
		border-radius: 8px;
		font-size: 0.88rem;
		color: var(--color-pearl-dim);
	}

	.pcm-dialog__opcoes label:has(input:checked) {
		background: rgba(201, 166, 107, 0.12);
		color: var(--color-pearl);
	}

	.pcm-dialog__opcoes input {
		accent-color: var(--color-sand);
		flex-shrink: 0;
	}

	.pcm-dialog__opcao-genero {
		align-items: flex-start !important;
	}

	.pcm-dialog__opcao-genero span {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.pcm-dialog__opcao-genero b {
		font-weight: 600;
		font-size: 0.88rem;
	}

	.pcm-dialog__opcao-genero small {
		color: var(--color-pearl-dim);
		font-size: 0.74rem;
		line-height: 1.4;
	}
</style>

<script>
	import { gsap } from "../scripts/gsap-setup";

	gsap.fromTo(
		".reveal",
		{ opacity: 0, y: 24 },
		{ opacity: 1, y: 0, duration: 0.8, stagger: 0.08, ease: "power3.out" }
	);

	const grid = document.querySelector<HTMLElement>(".portfolio-grid");
	const cards = grid ? (Array.from(grid.children) as HTMLElement[]) : [];
	const ordemOriginal = [...cards];

	const selectOrdenar = document.getElementById("portfolio-ordenar") as HTMLSelectElement | null;
	const selectGenero = document.getElementById("portfolio-filtro-genero") as HTMLSelectElement | null;
	const selectClassificacao = document.getElementById("portfolio-filtro-classificacao") as HTMLSelectElement | null;

	function valor(card: HTMLElement, attr: string): string {
		return card.getAttribute(attr) ?? "";
	}

	function aplicarOrdenacao(modo: string) {
		if (!grid) return;
		let ordenados = [...cards];

		if (modo === "titulo") {
			ordenados.sort((a, b) => valor(a, "data-titulo").localeCompare(valor(b, "data-titulo"), "pt-BR"));
		} else if (modo === "genero") {
			ordenados.sort((a, b) => {
				const generoA = valor(a, "data-genero");
				const generoB = valor(b, "data-genero");
				if (!generoA && generoB) return 1;
				if (generoA && !generoB) return -1;
				const cmp = generoA.localeCompare(generoB, "pt-BR");
				if (cmp !== 0) return cmp;
				return valor(a, "data-titulo").localeCompare(valor(b, "data-titulo"), "pt-BR");
			});
		} else if (modo === "duracao") {
			ordenados.sort((a, b) => {
				const duracaoA = valor(a, "data-duracao");
				const duracaoB = valor(b, "data-duracao");
				if (duracaoA === "" && duracaoB === "") return 0;
				if (duracaoA === "") return 1;
				if (duracaoB === "") return -1;
				return Number(duracaoA) - Number(duracaoB);
			});
		} else {
			ordenados = [...ordemOriginal];
		}

		ordenados.forEach((card) => grid.appendChild(card));
	}

	function aplicarFiltros() {
		const genero = selectGenero?.value ?? "";
		const classificacao = selectClassificacao?.value ?? "";
		cards.forEach((card) => {
			const bateGenero = !genero || valor(card, "data-genero") === genero;
			const bateClassificacao = !classificacao || valor(card, "data-classificacao") === classificacao;
			card.style.display = bateGenero && bateClassificacao ? "" : "none";
		});
	}

	selectOrdenar?.addEventListener("change", (e) => aplicarOrdenacao((e.target as HTMLSelectElement).value));
	selectGenero?.addEventListener("change", aplicarFiltros);
	selectClassificacao?.addEventListener("change", aplicarFiltros);

	// Botões-ícone do mobile: abrem um <dialog> centralizado por campo e
	// espelham a escolha no <select> correspondente, reaproveitando a
	// ordenação/filtro já ligados a eles acima.
	document.querySelectorAll<HTMLButtonElement>(".pcm-botao").forEach((botao) => {
		botao.addEventListener("click", () => {
			const id = botao.dataset.abre;
			const dialog = id ? (document.getElementById(id) as HTMLDialogElement | null) : null;
			dialog?.showModal();
		});
	});

	document.querySelectorAll<HTMLDialogElement>(".pcm-dialog").forEach((dialog) => {
		dialog.querySelector("[data-fecha]")?.addEventListener("click", () => dialog.close());
		dialog.addEventListener("click", (e) => {
			if (e.target === dialog) dialog.close();
		});
	});

	function ligarRadios(nome: string, select: HTMLSelectElement | null, dialogId: string) {
		const dialog = document.getElementById(dialogId) as HTMLDialogElement | null;
		const botao = document.querySelector<HTMLButtonElement>(`[data-abre="${dialogId}"]`);
		document.querySelectorAll<HTMLInputElement>(`input[name="${nome}"]`).forEach((radio) => {
			radio.addEventListener("change", () => {
				if (select) {
					select.value = radio.value;
					select.dispatchEvent(new Event("change"));
				}
				botao?.classList.toggle("is-ativo", radio.value !== "");
				dialog?.close();
			});
		});
	}

	ligarRadios("pcm-ordenar", selectOrdenar, "dialog-ordenar");
	ligarRadios("pcm-genero", selectGenero, "dialog-genero");
	ligarRadios("pcm-classificacao", selectClassificacao, "dialog-classificacao");
</script>
