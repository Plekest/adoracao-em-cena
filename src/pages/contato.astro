---
import BaseLayout from "../layouts/BaseLayout.astro";

// TODO: trocar pelo e-mail real do grupo
const EMAIL_DESTINO = "contato@adoracaoemcena.com.br";

const canais = [
	{
		nome: "WhatsApp",
		valor: "Fale com a gente",
		href: "https://wa.me/556195899902",
		icone: "whatsapp" as const,
	},
	{
		nome: "Instagram",
		valor: "@adoracaoemcena",
		href: "https://www.instagram.com/adoracaoemcena/",
		icone: "instagram" as const,
	},
	{
		nome: "YouTube",
		valor: "@adoracao-em-cena",
		href: "https://www.youtube.com/@adoracao-em-cena",
		icone: "youtube" as const,
	},
	{
		nome: "E-mail",
		valor: EMAIL_DESTINO,
		href: `mailto:${EMAIL_DESTINO}`,
		icone: "email" as const,
	},
];
---

<BaseLayout title="Contato - Adoração em Cena" description="Fale com o grupo Adoração em Cena pelo WhatsApp, Instagram ou e-mail.">
	<section class="contato section">
		<div class="container contato__inner">
			<p class="eyebrow reveal">Fale com a gente</p>
			<h1 class="reveal">Vamos conversar</h1>
			<p class="contato__intro reveal">
				Dúvidas, convites para apresentações ou só quer bater um papo sobre o grupo? Escolha o canal que
				preferir.
			</p>

			<form class="contato-form reveal" id="contato-form">
				<div class="contato-form__row">
					<label for="contato-nome">Nome</label>
					<input type="text" id="contato-nome" name="nome" required />
				</div>
				<div class="contato-form__row">
					<label for="contato-email">Seu e-mail</label>
					<input type="email" id="contato-email" name="email" required />
				</div>
				<div class="contato-form__row">
					<label for="contato-mensagem">Mensagem</label>
					<textarea id="contato-mensagem" name="mensagem" rows="5" required></textarea>
				</div>
				<button type="submit" class="btn btn-solid">Enviar mensagem</button>
			</form>

			<p class="contato__divisor reveal">ou escolha um canal</p>

			<div class="contato__grid">
				{
					canais.map((canal) => (
						<a
							class="canal-card reveal"
							href={canal.href}
							target={canal.href.startsWith("http") ? "_blank" : undefined}
							rel={canal.href.startsWith("http") ? "noopener noreferrer" : undefined}
						>
							<span class="canal-card__icone" aria-hidden="true">
								{canal.icone === "instagram" && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
										<rect x="3" y="3" width="18" height="18" rx="5" />
										<circle cx="12" cy="12" r="4.2" />
										<circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none" />
									</svg>
								)}
								{canal.icone === "youtube" && (
									<svg viewBox="0 0 24 24" fill="currentColor">
										<path d="M22 12c0-2.2-.2-3.8-.5-4.9-.3-1-1-1.7-2-2C17.7 4.6 12 4.6 12 4.6s-5.7 0-7.5.5c-1 .3-1.7 1-2 2C2.2 8.2 2 9.8 2 12s.2 3.8.5 4.9c.3 1 1 1.7 2 2 1.8.5 7.5.5 7.5.5s5.7 0 7.5-.5c1-.3 1.7-1 2-2 .3-1.1.5-2.7.5-4.9z" />
										<path d="M10 15.5v-7L15.5 12 10 15.5z" fill="var(--color-obsidian)" />
									</svg>
								)}
								{canal.icone === "whatsapp" && (
									<svg viewBox="0 0 24 24" fill="currentColor">
										<path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.38 1.26 4.8L2 22l5.42-1.36a9.9 9.9 0 0 0 4.62 1.14h.01c5.46 0 9.9-4.45 9.9-9.91C21.96 6.45 17.5 2 12.04 2zm5.8 14.03c-.24.68-1.4 1.3-1.93 1.38-.5.08-1.11.11-1.79-.11-.41-.13-.94-.3-1.62-.6-2.85-1.23-4.7-4.1-4.84-4.29-.14-.19-1.16-1.54-1.16-2.94 0-1.4.73-2.09.99-2.38.26-.28.57-.35.76-.35h.55c.18 0 .42-.02.65.5.24.53.82 1.86.9 1.99.07.13.12.28.02.46-.09.18-.14.29-.28.45-.14.16-.29.36-.42.48-.14.13-.28.28-.13.55.16.28.7 1.16 1.5 1.87 1.03.92 1.9 1.21 2.17 1.35.28.14.44.12.6-.07.16-.19.68-.79.87-1.06.18-.28.37-.23.61-.14.25.09 1.57.74 1.84.87.27.14.45.2.51.32.07.11.07.65-.17 1.33z" />
									</svg>
								)}
								{canal.icone === "email" && (
									<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
										<rect x="3" y="5" width="18" height="14" rx="2" />
										<path d="M3.5 6.5 12 13 20.5 6.5" />
									</svg>
								)}
							</span>
							<h2>{canal.nome}</h2>
							<p>{canal.valor}</p>
						</a>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.contato {
		min-height: 80vh;
		display: flex;
		align-items: center;
	}

	.contato__inner {
		text-align: center;
	}

	.contato__intro {
		color: var(--color-pearl-dim);
		max-width: 40ch;
		margin-inline: auto;
	}

	.contato-form {
		display: flex;
		flex-direction: column;
		gap: var(--space-md);
		max-width: 32rem;
		margin: var(--space-lg) auto 0;
		text-align: left;
	}

	.contato-form__row {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.contato-form__row label {
		font-size: 0.8rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-sand);
	}

	.contato-form__row input,
	.contato-form__row textarea {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-pearl);
		background: var(--color-obsidian-soft);
		border: 1px solid rgba(201, 166, 107, 0.25);
		border-radius: 10px;
		padding: 0.75rem 1rem;
		resize: vertical;
		transition: border-color 0.3s var(--ease-dramatic);
	}

	.contato-form__row input:focus,
	.contato-form__row textarea:focus {
		outline: none;
		border-color: var(--color-sand);
	}

	.contato-form .btn {
		align-self: center;
	}

	.contato__divisor {
		color: var(--color-pearl-dim);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-top: var(--space-lg);
	}

	.contato__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: var(--space-md);
		margin-top: var(--space-lg);
		max-width: 60rem;
		margin-inline: auto;
	}

	.canal-card {
		padding: var(--space-lg) var(--space-md);
		border: 1px solid rgba(201, 166, 107, 0.2);
		border-radius: 16px;
		background: linear-gradient(180deg, rgba(201, 166, 107, 0.05), transparent);
		transition: transform 0.35s var(--ease-dramatic), border-color 0.35s var(--ease-dramatic);
	}

	.canal-card:hover {
		transform: translateY(-6px);
		border-color: var(--color-sand);
	}

	.canal-card__icone {
		display: flex;
		justify-content: center;
		color: var(--color-sand);
		margin-bottom: var(--space-sm);
	}

	.canal-card__icone svg {
		width: 32px;
		height: 32px;
	}

	.canal-card h2 {
		font-size: 1.2rem;
		margin-bottom: 0.35rem;
	}

	.canal-card p {
		color: var(--color-pearl-dim);
		font-size: 0.9rem;
		margin: 0;
		word-break: break-word;
	}
</style>

<script>
	import { gsap } from "../scripts/gsap-setup";

	gsap.fromTo(
		".contato .reveal",
		{ opacity: 0, y: 24 },
		{ opacity: 1, y: 0, duration: 0.8, stagger: 0.08, ease: "power3.out" }
	);

	const form = document.getElementById("contato-form") as HTMLFormElement | null;

	form?.addEventListener("submit", (e) => {
		e.preventDefault();

		const nome = (document.getElementById("contato-nome") as HTMLInputElement).value;
		const email = (document.getElementById("contato-email") as HTMLInputElement).value;
		const mensagem = (document.getElementById("contato-mensagem") as HTMLTextAreaElement).value;

		const assunto = encodeURIComponent(`Contato pelo site - ${nome}`);
		const corpo = encodeURIComponent(`Nome: ${nome}\nE-mail: ${email}\n\n${mensagem}`);

		// TODO: trocar pelo e-mail real do grupo (mesmo endereço usado no card de e-mail acima)
		window.location.href = `mailto:contato@adoracaoemcena.com.br?subject=${assunto}&body=${corpo}`;
	});
</script>
