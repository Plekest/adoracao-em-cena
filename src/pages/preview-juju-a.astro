---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const peca = await getEntry("portfolio", "juju-e-leleco");
if (!peca) throw new Error("Conteúdo 'juju-e-leleco' não encontrado");

function getYoutubeId(url: string): string | null {
	const watch = url.match(/[?&]v=([^&]+)/);
	if (watch) return watch[1];
	const short = url.match(/youtu\.be\/([^?&]+)/);
	if (short) return short[1];
	return null;
}

const videoId = peca.data.video ? getYoutubeId(peca.data.video) : null;
const videosExtras = peca.data.videos
	.map((url) => getYoutubeId(url))
	.filter((id): id is string => Boolean(id));
---

<BaseLayout title="Prévia A - Juju & Leleco" description="Página de prévia, não indexada e não linkada no site.">
	<div class="preview-banner">Prévia · modelo A - Cortina Clássica · página não linkada no menu</div>

	<section class="palco">
		<div class="stage-wrap">
			<div class="curtain-side curtain-side--l"></div>
			<div class="curtain-side curtain-side--r"></div>
			<div class="floor"></div>
			<div class="hero">
				<span class="eyebrow reveal">Ministério Infantil</span>
				<h1 class="title reveal">{peca.data.titulo}</h1>
				<p class="synopsis reveal">{peca.data.sinopse ?? peca.data.descricao}</p>
				<div class="meta-row reveal">
					{peca.data.classificacao && <span class="meta-chip meta-chip--class">{peca.data.classificacao}</span>}
					{peca.data.duracao && <span class="meta-chip">{peca.data.duracao}</span>}
				</div>
				<a href="/contato" class="cta reveal">🎭 Ver o espetáculo</a>
			</div>
		</div>

		<div class="gallery-wrap">
			{
				videoId && (
					<button
						type="button"
						class="featured reveal"
						data-video-trigger
						data-video-id={videoId}
						aria-label={`Assistir teaser de ${peca.data.titulo}`}
					>
						<img src={`https://img.youtube.com/vi/${videoId}/hqdefault.jpg`} alt="" loading="lazy" />
						<span class="play"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg></span>
					</button>
				)
			}

			{
				videosExtras.length > 0 && (
					<>
						<p class="gallery-heading reveal">Próximas Cenas</p>
						<div class="grid4">
							{videosExtras.map((id) => (
								<button type="button" class="card reveal" data-video-trigger data-video-id={id} aria-label="Assistir vídeo">
									<img src={`https://img.youtube.com/vi/${id}/hqdefault.jpg`} alt="" loading="lazy" />
									<span class="play"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg></span>
								</button>
							))}
						</div>
					</>
				)
			}
		</div>
	</section>

	<div class="video-modal" id="video-modal" aria-hidden="true">
		<button type="button" class="video-modal__close" id="video-modal-close" aria-label="Fechar vídeo">
			<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
			</svg>
		</button>
		<div class="video-modal__frame" id="video-modal-frame"></div>
	</div>
</BaseLayout>

<style>
	.preview-banner {
		position: relative;
		z-index: 200;
		text-align: center;
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #0d0b0c;
		background: var(--color-sand);
		padding: 0.5rem 1rem;
	}

	.palco {
		--curtain: #8c1d2b;
		--curtain2: #5c1019;
		--gold: #c9a66b;
		--goldbright: #e3c893;
		background: var(--color-obsidian);
		font-family: "Futura", "Century Gothic", "Trebuchet MS", sans-serif;
		padding-bottom: var(--space-lg);
	}

	.stage-wrap {
		max-width: 1100px;
		margin: 0 auto;
		position: relative;
		padding-top: var(--space-md);
	}

	.curtain-side {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 13%;
		background: repeating-linear-gradient(90deg, var(--curtain) 0 16px, var(--curtain2) 16px 32px);
	}

	.curtain-side::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 10%;
		background: radial-gradient(circle at 50% 0, transparent 60%, var(--goldbright) 62%, transparent 64%);
		background-size: 24px 100%;
		opacity: 0.5;
	}

	.curtain-side--l {
		left: 0;
		border-radius: 0 60px 0 0;
	}

	.curtain-side--r {
		right: 0;
		border-radius: 60px 0 0 0;
	}

	.floor {
		position: absolute;
		left: 13%;
		right: 13%;
		bottom: 0;
		height: 14%;
		background: linear-gradient(180deg, transparent, rgba(90, 60, 30, 0.35));
	}

	.hero {
		position: relative;
		z-index: 2;
		padding: var(--space-xl) 1.5rem var(--space-lg);
		text-align: center;
	}

	.eyebrow {
		display: inline-block;
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		padding: 0.35rem 1rem;
		border-radius: 999px;
		margin-bottom: 1rem;
		background: var(--gold);
		color: #3a2400;
		font-weight: 700;
	}

	.title {
		margin: 0 0 1rem;
		line-height: 1;
		font-size: 3.2rem;
		color: #fff;
		text-transform: uppercase;
		letter-spacing: 0.02em;
		font-weight: 800;
	}

	.synopsis {
		max-width: 52ch;
		margin: 0 auto 1.25rem;
		font-size: 1.05rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.75);
	}

	.meta-row {
		display: flex;
		gap: 0.6rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 1.75rem;
	}

	.meta-chip {
		font-size: 0.78rem;
		padding: 0.3rem 0.85rem;
		border-radius: 999px;
		font-weight: 600;
		background: transparent;
		border: 1px solid var(--gold);
		color: var(--gold);
	}

	.meta-chip--class {
		background: var(--curtain);
		color: #fff;
		border-color: var(--curtain);
	}

	.cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.9rem 1.8rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.95rem;
		cursor: pointer;
		border: none;
		text-decoration: none;
		background: var(--gold);
		color: #3a2400;
	}

	.gallery-wrap {
		max-width: 920px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.gallery-heading {
		text-align: center;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin: 0 0 1.5rem;
		opacity: 0.7;
		color: var(--gold);
	}

	.featured,
	.card {
		position: relative;
		border-radius: 14px;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		border: 2px solid var(--gold);
		padding: 0;
		background: none;
		font: inherit;
		width: 100%;
	}

	.featured {
		aspect-ratio: 16 / 8;
		margin-bottom: 1.5rem;
	}

	.card {
		border-radius: 12px;
		aspect-ratio: 4 / 3;
	}

	.featured img,
	.card img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.grid4 {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
		gap: 1rem;
	}

	.play {
		position: relative;
		z-index: 1;
		width: 56px;
		height: 56px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		background: var(--gold);
	}

	.play svg {
		width: 20px;
		height: 20px;
		margin-left: 3px;
	}

	.play svg path {
		fill: #3a2400;
	}

	.card .play {
		width: 38px;
		height: 38px;
	}

	.card .play svg {
		width: 14px;
		height: 14px;
	}

	@media (max-width: 720px) {
		.curtain-side {
			width: 6%;
		}

		.title {
			font-size: 2.1rem;
		}
	}

	/* ---------- Modal de vídeo ---------- */
	.video-modal {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: rgba(8, 7, 7, 0.94);
		align-items: center;
		justify-content: center;
		padding: var(--space-md);
	}

	.video-modal.is-open {
		display: flex;
	}

	.video-modal__frame {
		position: relative;
		width: min(100%, 1100px);
		aspect-ratio: 16 / 9;
	}

	.video-modal__frame iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: 0;
		border-radius: 10px;
		background: #000;
	}

	.video-modal__close {
		position: absolute;
		top: var(--space-sm);
		right: var(--space-sm);
		width: 42px;
		height: 42px;
		border-radius: 50%;
		border: 1px solid rgba(242, 236, 228, 0.3);
		background: rgba(13, 11, 12, 0.6);
		color: var(--color-pearl);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
	}

	.video-modal__close svg {
		width: 18px;
		height: 18px;
	}
</style>

<script>
	import { gsap } from "../scripts/gsap-setup";

	gsap.fromTo(".reveal", { opacity: 0, y: 24 }, { opacity: 1, y: 0, duration: 0.8, stagger: 0.06, ease: "power3.out" });

	const modal = document.getElementById("video-modal");
	const modalFrame = document.getElementById("video-modal-frame");
	const closeBtn = document.getElementById("video-modal-close");

	function closeModal() {
		if (!modal || !modalFrame) return;
		modal.classList.remove("is-open");
		modal.setAttribute("aria-hidden", "true");
		modalFrame.innerHTML = "";
	}

	function openModal(videoId: string) {
		if (!modal || !modalFrame || !videoId) return;
		modalFrame.innerHTML = "";
		const iframe = document.createElement("iframe");
		iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0`;
		iframe.title = "Vídeo";
		iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
		iframe.allowFullscreen = true;
		iframe.style.cssText = "position:absolute;inset:0;width:100%;height:100%;border:0;border-radius:10px;background:#000;";
		modalFrame.appendChild(iframe);
		modal.classList.add("is-open");
		modal.setAttribute("aria-hidden", "false");
	}

	document.querySelectorAll("[data-video-trigger]").forEach((el) => {
		el.addEventListener("click", () => openModal(el.getAttribute("data-video-id") ?? ""));
	});

	closeBtn?.addEventListener("click", closeModal);
	modal?.addEventListener("click", (e) => {
		if (e.target === modal) closeModal();
	});
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") closeModal();
	});
</script>
