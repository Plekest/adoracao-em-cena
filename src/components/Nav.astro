---
const links = [
	{ href: "/", label: "Início" },
	{ href: "/portfolio", label: "Portfólio" },
	{ href: "/contato", label: "Contato" },
];
const currentPath = Astro.url.pathname;
---

<header class="nav" id="site-nav">
	<div class="nav__inner container">
		<a href="/" class="nav__brand" aria-label="Adoração em Cena — início">
			<img src="/logo.svg" alt="Adoração em Cena" width="180" height="64" />
		</a>

		<button class="nav__toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Abrir menu">
			<span></span>
			<span></span>
			<span></span>
		</button>

		<nav class="nav__menu" id="nav-menu">
			{
				links.map((link) => (
					<a
						href={link.href}
						class:list={["nav__link", { "nav__link--active": currentPath === link.href }]}
					>
						{link.label}
					</a>
				))
			}
			<a
				href="https://www.instagram.com/t7adoracaoemcena/"
				target="_blank"
				rel="noopener noreferrer"
				class="nav__link nav__link--insta"
			>
				Instagram
			</a>
		</nav>
	</div>
</header>

<style>
	.nav {
		position: fixed;
		inset-inline: 0;
		top: 0;
		z-index: 100;
		padding-block: var(--space-sm);
		background: transparent;
		transition: background-color 0.4s var(--ease-dramatic), backdrop-filter 0.4s var(--ease-dramatic), padding 0.4s var(--ease-dramatic);
	}

	.nav.is-scrolled {
		background: rgba(13, 11, 12, 0.85);
		backdrop-filter: blur(10px);
		padding-block: 0.6rem;
		box-shadow: 0 1px 0 rgba(201, 166, 107, 0.15);
	}

	.nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
	}

	.nav__brand img {
		height: 48px;
		width: auto;
	}

	.nav__toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
		z-index: 101;
	}

	.nav__toggle span {
		width: 24px;
		height: 2px;
		background: var(--color-pearl);
		transition: transform 0.3s var(--ease-dramatic), opacity 0.3s var(--ease-dramatic);
	}

	.nav__menu {
		display: flex;
		align-items: center;
		gap: var(--space-md);
	}

	.nav__link {
		font-size: 0.9rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-pearl);
		position: relative;
		padding-block: 0.25rem;
	}

	.nav__link::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: -2px;
		width: 0%;
		height: 1px;
		background: var(--color-sand);
		transition: width 0.35s var(--ease-dramatic);
	}

	.nav__link:hover::after,
	.nav__link--active::after {
		width: 100%;
	}

	.nav__link--active {
		color: var(--color-sand);
	}

	.nav__link--insta {
		color: var(--color-crimson-bright);
	}

	@media (max-width: 720px) {
		.nav__toggle {
			display: flex;
		}

		.nav__menu {
			position: fixed;
			inset: 0;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: var(--space-lg);
			background: var(--color-obsidian);
			transform: translateX(100%);
			transition: transform 0.4s var(--ease-dramatic);
		}

		.nav__menu.is-open {
			transform: translateX(0);
		}

		.nav__link {
			font-size: 1.25rem;
		}
	}
</style>

<script>
	const nav = document.getElementById("site-nav");
	const toggle = document.getElementById("nav-toggle");
	const menu = document.getElementById("nav-menu");

	const onScroll = () => {
		if (!nav) return;
		nav.classList.toggle("is-scrolled", window.scrollY > 40);
	};
	onScroll();
	window.addEventListener("scroll", onScroll, { passive: true });

	toggle?.addEventListener("click", () => {
		const isOpen = menu?.classList.toggle("is-open");
		toggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
	});

	menu?.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			menu.classList.remove("is-open");
			toggle?.setAttribute("aria-expanded", "false");
		});
	});
</script>
