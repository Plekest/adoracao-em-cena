---
import { generos } from "../../lib/generos";

const entradas = Object.entries(generos);
---

<span class="generos-legenda" tabindex="0" role="button" aria-label="O que significa cada gênero?" aria-describedby="generos-legenda-tooltip">
	<svg class="generos-legenda__icone" aria-hidden="true" viewBox="0 0 16 16" fill="none">
		<circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.2" />
		<path
			d="M6.1 6.1c0-1.05.85-1.7 1.9-1.7s1.9.55 1.9 1.5c0 1.3-1.9 1.25-1.9 2.75"
			stroke="currentColor"
			stroke-width="1.2"
			stroke-linecap="round"
		/>
		<circle cx="8" cy="11.3" r="0.15" fill="currentColor" stroke="currentColor" stroke-width="0.9" />
	</svg>
	<span class="generos-legenda__tooltip" role="tooltip" id="generos-legenda-tooltip">
		<strong>Gêneros das peças</strong>
		<dl>
			{
				entradas.map(([nome, info]) => (
					<div>
						<dt>{nome}</dt>
						<dd>{info.definicao}</dd>
					</div>
				))
			}
		</dl>
	</span>
</span>

<style>
	.generos-legenda {
		position: relative;
		display: inline-flex;
		align-items: center;
		width: 1.1em;
		height: 1.1em;
		color: var(--color-sand);
		cursor: help;
		z-index: 1;
	}

	.generos-legenda__icone {
		width: 1.1em;
		height: 1.1em;
		pointer-events: none;
	}

	.generos-legenda__tooltip {
		display: none;
		position: absolute;
		top: calc(100% + 1.5rem);
		pointer-events: none;
		left: 50%;
		transform: translateX(-50%);
		width: max-content;
		max-width: min(320px, calc(100vw - 2.5rem));
		padding: 0.8rem 1rem;
		border: 1px solid rgba(201, 166, 107, 0.35);
		border-radius: 10px;
		background: var(--color-obsidian-soft);
		color: var(--color-pearl-dim);
		font-size: 0.8rem;
		font-weight: 400;
		line-height: 1.4;
		text-align: left;
		text-transform: none;
		letter-spacing: normal;
		box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.6);
		z-index: 10;
	}

	.generos-legenda__tooltip strong {
		display: block;
		margin-bottom: 0.5rem;
		color: var(--color-sand);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.generos-legenda__tooltip dl {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.generos-legenda__tooltip dt {
		color: var(--color-pearl);
		font-size: 0.8rem;
		font-weight: 600;
	}

	.generos-legenda__tooltip dd {
		margin: 0.1rem 0 0;
	}

	.generos-legenda:hover .generos-legenda__tooltip,
	.generos-legenda:focus-visible .generos-legenda__tooltip {
		display: block;
	}
</style>
