---
import type { CollectionEntry } from "astro:content";
import { duracaoConcisa, duracaoParaSegundos } from "../../lib/portfolio";
import { generos } from "../../lib/generos";

interface Props {
	peca: CollectionEntry<"portfolio">;
	desbloqueada: boolean;
}

const { peca, desbloqueada } = Astro.props;

const duracaoCurta = duracaoConcisa(peca.data.duracao);
const duracaoSegundos = duracaoParaSegundos(peca.data.duracao);
const capa = peca.data.fotos[0];
const inicial = peca.data.titulo.trim().charAt(0).toUpperCase();
const glow = (peca.data.genero && generos[peca.data.genero]?.corGlow) || "rgba(201, 166, 107, 0.2)";
---

{
	desbloqueada ? (
		<a
			href={`/portfolio/${peca.id}`}
			class="peca-card"
			data-titulo={peca.data.titulo}
			data-genero={peca.data.genero ?? ""}
			data-classificacao={peca.data.classificacao ?? ""}
			data-duracao={duracaoSegundos ?? ""}
			style={`--glow: ${glow}`}
		>
			<div class="peca-card__arte" data-letra={inicial} style={capa && `background-image: url(${capa})`} />
			<div class="peca-card__scrim" />
			<div class="peca-card__topo">
				<div class="peca-card__topo-grupo">
					{peca.data.genero && <span class="peca-card__pill">{peca.data.genero}</span>}
					{peca.data.classificacao && (
						<span class="peca-card__pill peca-card__pill--classificacao">{peca.data.classificacao}</span>
					)}
					{duracaoCurta && <span class="peca-card__pill peca-card__pill--duracao">{duracaoCurta}</span>}
				</div>
			</div>
			<div class="peca-card__base">
				<h3>{peca.data.titulo}</h3>
				<p class="peca-card__desc">{peca.data.descricao}</p>
				<span class="peca-card__link">Ver detalhes →</span>
			</div>
		</a>
	) : (
		<div
			class="peca-card peca-card--bloqueada"
			aria-disabled="true"
			data-titulo={peca.data.titulo}
			data-genero={peca.data.genero ?? ""}
			data-classificacao={peca.data.classificacao ?? ""}
			data-duracao={duracaoSegundos ?? ""}
		>
			<div class="peca-card__arte" data-letra={inicial} style={capa && `background-image: url(${capa})`} />
			<div class="peca-card__scrim" />
			<div class="peca-card__topo">
				<span class="peca-card__pill">Em breve</span>
			</div>
			<div class="peca-card__base">
				<h3>{peca.data.titulo}</h3>
				<p class="peca-card__desc">{peca.data.descricao}</p>
			</div>
		</div>
	)
}

<style>
	.peca-card {
		position: relative;
		display: block;
		aspect-ratio: 4 / 5;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid rgba(201, 166, 107, 0.25);
		box-shadow: 0 25px 45px -25px rgba(0, 0, 0, 0.7);
		isolation: isolate;
		transition: transform 0.4s var(--ease-dramatic), border-color 0.4s var(--ease-dramatic);
	}

	.peca-card:hover {
		transform: translateY(-6px);
		border-color: var(--color-sand);
	}

	.peca-card--bloqueada {
		cursor: default;
	}

	.peca-card--bloqueada:hover {
		transform: none;
		border-color: rgba(201, 166, 107, 0.25);
	}

	.peca-card--bloqueada .peca-card__arte {
		filter: grayscale(0.6);
		opacity: 0.7;
	}

	.peca-card__arte {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		background-color: var(--color-obsidian-soft);
		background-image: radial-gradient(ellipse 90% 55% at 50% 12%, var(--glow, rgba(201, 166, 107, 0.24)), transparent 65%),
			linear-gradient(180deg, var(--color-obsidian-soft) 0%, var(--color-obsidian) 100%);
	}

	.peca-card__arte::before {
		content: attr(data-letra);
		position: absolute;
		right: -0.3rem;
		top: -1.1rem;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 7rem;
		color: var(--color-pearl);
		opacity: 0.06;
		line-height: 1;
	}

	.peca-card__scrim {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 40%, rgba(13, 11, 12, 0.88) 100%);
	}

	.peca-card__topo {
		position: absolute;
		top: 0.7rem;
		left: 0.7rem;
		right: 0.7rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.4rem;
		z-index: 2;
	}

	.peca-card__topo-grupo {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.35rem;
	}

	.peca-card__pill--classificacao {
		background: rgba(140, 29, 43, 0.55);
		border-color: rgba(179, 44, 61, 0.6);
		font-size: 0.5rem;
	}

	.peca-card__pill {
		background: rgba(13, 11, 12, 0.55);
		border: 1px solid rgba(242, 236, 228, 0.35);
		color: var(--color-pearl);
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.peca-card__pill--duracao {
		font-variant-numeric: tabular-nums;
	}

	.peca-card__base {
		position: absolute;
		left: 0.9rem;
		right: 0.9rem;
		bottom: 0.85rem;
		z-index: 2;
	}

	.peca-card__base h3 {
		margin: 0 0 0.4rem;
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 1.1rem;
		color: var(--color-pearl);
		text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
	}

	.peca-card__desc {
		margin: 0 0 0.6rem;
		color: var(--color-pearl-dim);
		font-size: 0.82rem;
		line-height: 1.45;
	}

	.peca-card__link {
		display: inline-block;
		color: var(--color-sand);
		font-size: 0.8rem;
	}
</style>
