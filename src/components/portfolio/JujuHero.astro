---
import type { CollectionEntry } from "astro:content";

interface Props {
	peca: CollectionEntry<"portfolio">;
	videoId: string | null;
	videosExtras: { url: string; id: string }[];
}

const { peca, videoId, videosExtras } = Astro.props;
---

<section class="palco">
	<div class="hero">
		<p class="flourish reveal">✦ ✦ ✦</p>
		<span class="eyebrow reveal">Ministério Infantil</span>
		<h1 class="title reveal">{peca.data.titulo}</h1>
		<p class="synopsis reveal">{peca.data.sinopse ?? peca.data.descricao}</p>
		{
			peca.data.atores && peca.data.atores.length > 0 && (
				<p class="elenco reveal">
					Estrelando: <b>Juju</b> &amp; <b>Leleco</b> · {peca.data.atores.join(", ")}
				</p>
			)
		}
		<div class="meta-row reveal">
			{peca.data.classificacao && <span class="meta-chip meta-chip--class">{peca.data.classificacao}</span>}
			{peca.data.duracao && <span class="meta-chip">{peca.data.duracao}</span>}
		</div>
		<a href="/contato" class="cta reveal">Ver o espetáculo</a>
	</div>

	<div class="ticket-divider reveal">✦</div>

	<div class="gallery-wrap">
		{
			videoId && (
				<button
					type="button"
					class="featured reveal"
					data-video-trigger
					data-video-id={videoId}
					aria-label={`Assistir teaser de ${peca.data.titulo}`}
				>
					<img src={`https://img.youtube.com/vi/${videoId}/hqdefault.jpg`} alt="" loading="lazy" />
					<span class="play">
						<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
					</span>
				</button>
			)
		}

		{
			videosExtras.length > 0 && (
				<>
					<p class="gallery-heading reveal">Próximas cenas</p>
					<div class="grid4">
						{videosExtras.map((v) => (
							<button type="button" class="card reveal" data-video-trigger data-video-id={v.id} aria-label="Assistir vídeo">
								<img src={`https://img.youtube.com/vi/${v.id}/hqdefault.jpg`} alt="" loading="lazy" />
								<span class="play">
									<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
								</span>
							</button>
						))}
					</div>
				</>
			)
		}
	</div>
</section>

<style>
	.palco {
		--crimson: #8c1d2b;
		--gold: #c9a66b;
		--pearl: #f2ece4;
		background: var(--color-obsidian);
		font-family: "Playfair Display", Georgia, serif;
		padding-bottom: var(--space-lg);
	}

	.hero {
		max-width: 640px;
		margin: 0 auto;
		padding: var(--space-xl) 1.5rem 0;
		text-align: center;
	}

	.flourish {
		color: var(--gold);
		font-size: 1.1rem;
		margin: 0 0 0.5rem;
		letter-spacing: 0.4em;
	}

	.eyebrow {
		display: inline-block;
		font-family: var(--font-body);
		color: var(--gold);
		letter-spacing: 0.3em;
		font-size: 0.72rem;
		text-transform: uppercase;
		margin-bottom: 1rem;
	}

	.title {
		margin: 0 0 1rem;
		line-height: 1.05;
		font-family: "Playfair Display", Georgia, serif;
		font-style: italic;
		font-weight: 700;
		font-size: 3.4rem;
		color: var(--pearl);
	}

	.synopsis {
		max-width: 52ch;
		margin: 0 auto 1rem;
		font-size: 1.05rem;
		line-height: 1.6;
		color: rgba(242, 236, 228, 0.75);
	}

	.elenco {
		font-family: var(--font-body);
		font-size: 0.85rem;
		color: var(--gold);
		letter-spacing: 0.05em;
		margin-bottom: 1.5rem;
	}

	.elenco b {
		color: var(--pearl);
	}

	.meta-row {
		display: flex;
		gap: 0.6rem;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 1.75rem;
	}

	.meta-chip {
		font-size: 0.78rem;
		padding: 0.3rem 0.85rem;
		font-weight: 600;
		background: transparent;
		border: 1px solid var(--gold);
		color: var(--gold);
	}

	.meta-chip--class {
		background: var(--crimson);
		color: #fff;
		border-color: var(--crimson);
	}

	.cta {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.9rem 1.8rem;
		font-weight: 700;
		font-family: var(--font-body);
		letter-spacing: 0.08em;
		font-size: 0.9rem;
		cursor: pointer;
		border: 1.5px solid var(--gold);
		background: transparent;
		color: var(--gold);
		text-decoration: none;
		text-transform: uppercase;
		transition: background-color 0.3s var(--ease-dramatic), color 0.3s var(--ease-dramatic);
	}

	.cta:hover {
		background: var(--gold);
		color: #3a2400;
	}

	.ticket-divider {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		max-width: 640px;
		margin: 0 auto var(--space-lg);
		padding: 0 1.5rem;
		color: rgba(242, 236, 228, 0.3);
		text-align: center;
	}

	.ticket-divider::before,
	.ticket-divider::after {
		content: "";
		flex: 1;
		border-top: 1px dashed rgba(242, 236, 228, 0.3);
	}

	.gallery-wrap {
		max-width: 920px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.gallery-heading {
		text-align: center;
		font-family: "Playfair Display", serif;
		font-style: italic;
		font-size: 1.2rem;
		margin: 0 0 1.5rem;
		color: var(--gold);
	}

	.featured,
	.card {
		position: relative;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		padding: 0;
		background: none;
		font: inherit;
		width: 100%;
	}

	.featured {
		border: 1px solid var(--gold);
		border-radius: 2px;
		aspect-ratio: 16 / 8;
		margin-bottom: 1.5rem;
	}

	/* Cards no estilo Marionete */
	.card {
		--wood: #8a6a3f;
		border: 2px solid var(--wood);
		border-radius: 6px;
		aspect-ratio: 4 / 3;
		margin-top: 16px;
	}

	.card::before,
	.card::after {
		content: "";
		position: absolute;
		top: -16px;
		width: 1px;
		height: 16px;
		background: rgba(242, 236, 228, 0.3);
	}

	.card::before {
		left: 30%;
	}

	.card::after {
		left: 70%;
	}

	.card:nth-child(odd) {
		transform: rotate(-1.5deg);
	}

	.card:nth-child(even) {
		transform: rotate(1.5deg);
	}

	.featured img,
	.card img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.grid4 {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
		gap: 1rem;
	}

	.play {
		position: relative;
		z-index: 1;
		width: 56px;
		height: 56px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		background: var(--gold);
	}

	.play svg {
		width: 20px;
		height: 20px;
		margin-left: 3px;
	}

	.play svg path {
		fill: #0d0b0c;
	}

	.card .play {
		width: 38px;
		height: 38px;
	}

	.card .play svg {
		width: 14px;
		height: 14px;
	}

	@media (max-width: 720px) {
		.title {
			font-size: 2.1rem;
		}
	}
</style>
