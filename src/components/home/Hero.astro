<section class="hero" id="hero">
	<span class="hero__glow" aria-hidden="true"></span>

	<div class="hero__content">
		<p class="eyebrow">Grupo de Drama</p>
		<img class="hero__logo" src="/logo.svg" alt="Adoração em Cena" width="640" height="452" />
		<p class="hero__tagline">Arte, fé e emoção ganhando vida em cena.</p>
		<div class="hero__cta">
			<a href="#sobre" class="btn">Conheça o grupo</a>
			<a href="/portfolio" class="btn btn-solid">Ver portfólio</a>
		</div>
	</div>

	<a href="#sobre" class="hero__scroll" aria-label="Rolar para a próxima seção">
		<span class="hero__scroll-line"></span>
		<span class="hero__scroll-label">Role</span>
	</a>

	<div class="hero__curtain hero__curtain--left" aria-hidden="true"></div>
	<div class="hero__curtain hero__curtain--right" aria-hidden="true"></div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		background: radial-gradient(ellipse at 50% 30%, var(--color-obsidian-soft) 0%, var(--color-obsidian) 70%);
	}

	.hero__glow {
		position: absolute;
		top: 50%;
		left: 50%;
		width: 60vmax;
		height: 60vmax;
		transform: translate(-50%, -50%);
		background: radial-gradient(circle, rgba(201, 166, 107, 0.16) 0%, rgba(140, 29, 43, 0.08) 45%, transparent 70%);
		pointer-events: none;
	}

	.hero__content {
		position: relative;
		z-index: 2;
		text-align: center;
		padding-inline: var(--space-md);
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero__logo {
		width: min(520px, 80vw);
		height: auto;
		margin-bottom: var(--space-sm);
	}

	.hero__tagline {
		font-family: var(--font-display);
		font-style: italic;
		font-size: clamp(1.1rem, 2vw, 1.5rem);
		color: var(--color-pearl-dim);
		max-width: 34ch;
	}

	.hero__cta {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-sm);
		justify-content: center;
		margin-top: var(--space-md);
	}

	.hero__scroll {
		position: absolute;
		bottom: var(--space-md);
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		z-index: 2;
	}

	.hero__scroll-line {
		width: 1px;
		height: 40px;
		background: linear-gradient(var(--color-sand), transparent);
		animation: scroll-hint 2s ease-in-out infinite;
	}

	.hero__scroll-label {
		font-size: 0.7rem;
		letter-spacing: 0.3em;
		text-transform: uppercase;
		color: var(--color-pearl-dim);
	}

	@keyframes scroll-hint {
		0%,
		100% {
			opacity: 0.3;
			transform: scaleY(0.6);
			transform-origin: top;
		}
		50% {
			opacity: 1;
			transform: scaleY(1);
			transform-origin: top;
		}
	}

	.hero__curtain {
		position: absolute;
		inset: 0;
		width: 51%;
		background: var(--color-obsidian);
		z-index: 3;
	}

	.hero__curtain--left {
		left: 0;
		border-right: 1px solid rgba(201, 166, 107, 0.1);
	}

	.hero__curtain--right {
		right: 0;
		left: auto;
		border-left: 1px solid rgba(201, 166, 107, 0.1);
	}

	@media (prefers-reduced-motion: reduce) {
		.hero__scroll-line {
			animation: none;
		}
	}
</style>

<script>
	import { gsap } from "../../scripts/gsap-setup";

	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	if (prefersReducedMotion) {
		gsap.set([".hero__curtain--left", ".hero__curtain--right"], { autoAlpha: 0 });
	} else {
		gsap.set(".hero__content", { opacity: 0, y: 30 });

		const tl = gsap.timeline({ defaults: { ease: "power4.inOut" }, delay: 0.2 });
		tl.to(".hero__curtain--left", { xPercent: -100, duration: 1.3 })
			.to(".hero__curtain--right", { xPercent: 100, duration: 1.3 }, "<")
			.to(".hero__content", { opacity: 1, y: 0, duration: 1 }, "-=0.7");

		gsap.to(".hero__glow", {
			yPercent: 20,
			ease: "none",
			scrollTrigger: {
				trigger: ".hero",
				start: "top top",
				end: "bottom top",
				scrub: true,
			},
		});
	}
</script>
