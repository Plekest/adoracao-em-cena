---
// Coloque os arquivos em public/galeria/ e liste os caminhos aqui, ex: "/galeria/01.jpg"
const fotos: string[] = [
	"/galeria/1.jpeg",
	"/galeria/2.jpeg",
	"/galeria/3.jpeg",
	"/galeria/4.jpeg",
	"/galeria/5.jpeg",
	"/galeria/6.jpeg",
	"/galeria/7.jpeg",
	"/galeria/8.jpeg",
	"/galeria/9.jpeg",
	"/galeria/10.jpeg",
];

const slidesPlaceholder = [1, 2, 3, 4, 5];
---

<section class="carrossel section" id="galeria">
	<div class="container carrossel__heading">
		<div>
			<p class="eyebrow">Bastidores</p>
			<h2>Nossos momentos em cena</h2>
			<p class="carrossel__sub">Registros de ensaios, apresentações e momentos que marcam nossa caminhada em cena.</p>
		</div>

		<div class="carrossel__nav">
			{
				fotos.length > 0 && (
					<button
						type="button"
						class="carrossel__arrow"
						id="carrossel-fullscreen"
						aria-label="Ver fotos em tela cheia"
					>
						<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path
								d="M8 4H5a1 1 0 0 0-1 1v3M16 4h3a1 1 0 0 1 1 1v3M20 16v3a1 1 0 0 1-1 1h-3M4 16v3a1 1 0 0 0 1 1h3"
								stroke="currentColor"
								stroke-width="1.8"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</button>
				)
			}
			<button type="button" class="carrossel__arrow" id="carrossel-prev" aria-label="Foto anterior">←</button>
			<button type="button" class="carrossel__arrow" id="carrossel-next" aria-label="Próxima foto">→</button>
		</div>
	</div>

	<div class="carrossel__viewport">
		<div class="carrossel__track" id="carrossel-track">
			{
				fotos.length > 0
					? fotos.map((foto, i) => (
							<figure class="carrossel__slide carrossel__slide--foto">
								<img
									src={foto}
									alt="Adoração em Cena"
									loading="lazy"
									draggable="false"
									data-lightbox-trigger
									data-index={i}
								/>
							</figure>
						))
					: slidesPlaceholder.map((n) => (
							<figure class="carrossel__slide" style={`--hue: ${n}`}>
								<span class="carrossel__slide-index">{String(n).padStart(2, "0")}</span>
								<figcaption>Foto do grupo em breve</figcaption>
							</figure>
						))
			}
		</div>
	</div>

	{
		fotos.length > 0 && (
			<div class="lightbox" id="carrossel-lightbox" aria-hidden="true">
				<button type="button" class="lightbox__close" id="lightbox-close" aria-label="Fechar">
					<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
					</svg>
				</button>
				<button type="button" class="lightbox__nav lightbox__nav--prev" id="lightbox-prev" aria-label="Foto anterior">
					←
				</button>
				<img class="lightbox__img" id="lightbox-img" src="" alt="Adoração em Cena" />
				<button type="button" class="lightbox__nav lightbox__nav--next" id="lightbox-next" aria-label="Próxima foto">
					→
				</button>
			</div>
		)
	}
</section>

<style>
	.carrossel__heading {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: var(--space-md);
		flex-wrap: wrap;
		margin-bottom: var(--space-md);
	}

	.carrossel__nav {
		display: flex;
		gap: 0.75rem;
		flex-shrink: 0;
	}

	.carrossel__sub {
		color: var(--color-pearl-dim);
		max-width: 50ch;
	}

	.carrossel__viewport {
		position: relative;
		width: 100%;
	}

	.carrossel__track {
		display: flex;
		gap: var(--space-sm);
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		padding-inline: max(1rem, calc((100vw - var(--container-width)) / 2));
		scroll-padding-inline: max(1rem, calc((100vw - var(--container-width)) / 2));
		padding-block: 0.5rem;
		scrollbar-width: none;
		cursor: grab;
		user-select: none;
	}

	.carrossel__track.is-dragging {
		cursor: grabbing;
		scroll-snap-type: none;
	}

	.carrossel__track::-webkit-scrollbar {
		display: none;
	}

	.carrossel__slide {
		flex: 0 0 min(340px, 80vw);
		aspect-ratio: 4 / 5;
		scroll-snap-align: start;
		border-radius: 16px;
		border: 1px solid rgba(201, 166, 107, 0.2);
		background: linear-gradient(
			160deg,
			color-mix(in srgb, var(--color-crimson) calc(10% + var(--hue) * 3%), var(--color-obsidian-soft)),
			var(--color-obsidian) 80%
		);
		margin: 0;
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: var(--space-md);
		overflow: hidden;
	}

	.carrossel__slide--foto {
		padding: 0;
	}

	.carrossel__slide--foto img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.carrossel__slide-index {
		position: absolute;
		top: var(--space-sm);
		left: var(--space-sm);
		font-family: var(--font-display);
		font-size: 2rem;
		color: rgba(201, 166, 107, 0.35);
	}

	.carrossel__slide figcaption {
		color: var(--color-pearl-dim);
		font-size: 0.9rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.carrossel__arrow {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		border: 1px solid var(--color-sand);
		background: transparent;
		color: var(--color-sand);
		font-size: 1.1rem;
		cursor: pointer;
		transition: background-color 0.3s var(--ease-dramatic), color 0.3s var(--ease-dramatic);
	}

	.carrossel__arrow:hover {
		background: var(--color-sand);
		color: var(--color-obsidian);
	}

	.carrossel__arrow svg {
		width: 18px;
		height: 18px;
		display: block;
		margin: auto;
	}

	@media (max-width: 600px) {
		.carrossel__nav {
			display: none;
		}
	}

	.lightbox {
		display: none;
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: rgba(8, 7, 7, 0.94);
		align-items: center;
		justify-content: center;
		padding: var(--space-md);
	}

	.lightbox.is-open {
		display: flex;
	}

	.lightbox__img {
		max-width: min(92vw, 1100px);
		max-height: 88vh;
		object-fit: contain;
		border-radius: 8px;
	}

	.lightbox__close {
		position: absolute;
		top: var(--space-sm);
		right: var(--space-sm);
		width: 42px;
		height: 42px;
		border-radius: 50%;
		border: 1px solid rgba(242, 236, 228, 0.3);
		background: rgba(13, 11, 12, 0.6);
		color: var(--color-pearl);
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: border-color 0.3s var(--ease-dramatic);
	}

	.lightbox__close:hover {
		border-color: var(--color-sand);
	}

	.lightbox__close svg {
		width: 18px;
		height: 18px;
	}

	.lightbox__nav {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 48px;
		height: 48px;
		border-radius: 50%;
		border: 1px solid var(--color-sand);
		background: rgba(13, 11, 12, 0.6);
		color: var(--color-sand);
		font-size: 1.1rem;
		cursor: pointer;
		transition: background-color 0.3s var(--ease-dramatic), color 0.3s var(--ease-dramatic);
	}

	.lightbox__nav:hover {
		background: var(--color-sand);
		color: var(--color-obsidian);
	}

	.lightbox__nav--prev {
		left: var(--space-sm);
	}

	.lightbox__nav--next {
		right: var(--space-sm);
	}

	@media (max-width: 600px) {
		.lightbox__nav {
			width: 40px;
			height: 40px;
		}
	}
</style>

<script>
	import { gsap } from "../../scripts/gsap-setup";

	const track = document.getElementById("carrossel-track") as HTMLElement | null;
	const prev = document.getElementById("carrossel-prev");
	const next = document.getElementById("carrossel-next");

	const scrollByStep = (dir: number) => {
		if (!track) return;
		const slide = track.querySelector(".carrossel__slide");
		const step = slide ? slide.clientWidth + 16 : 300;
		const maxScroll = track.scrollWidth - track.clientWidth;

		if (dir > 0 && track.scrollLeft >= maxScroll - 4) {
			track.scrollTo({ left: 0, behavior: "smooth" });
		} else if (dir < 0 && track.scrollLeft <= 4) {
			track.scrollTo({ left: maxScroll, behavior: "smooth" });
		} else {
			track.scrollBy({ left: dir * step, behavior: "smooth" });
		}
	};

	prev?.addEventListener("click", () => scrollByStep(-1));
	next?.addEventListener("click", () => scrollByStep(1));

	const fullscreenBtn = document.getElementById("carrossel-fullscreen");
	fullscreenBtn?.addEventListener("click", () => {
		if (!track) {
			openLightbox(0);
			return;
		}
		const slide = track.querySelector(".carrossel__slide");
		const step = slide ? (slide as HTMLElement).clientWidth + 16 : 300;
		openLightbox(Math.round(track.scrollLeft / step));
	});

	let dragMoved = false;

	if (track) {
		let isDragging = false;
		let startX = 0;
		let startScroll = 0;

		track.addEventListener("pointerdown", (e) => {
			if (e.pointerType !== "mouse") return;
			isDragging = true;
			dragMoved = false;
			startX = e.clientX;
			startScroll = track.scrollLeft;
			track.classList.add("is-dragging");
			track.setPointerCapture(e.pointerId);
		});

		track.addEventListener("pointermove", (e) => {
			if (!isDragging) return;
			if (Math.abs(e.clientX - startX) > 5) dragMoved = true;
			track.scrollLeft = startScroll - (e.clientX - startX);
		});

		const endDrag = (e: PointerEvent) => {
			isDragging = false;
			track.classList.remove("is-dragging");
			if (track.hasPointerCapture(e.pointerId)) track.releasePointerCapture(e.pointerId);
		};

		track.addEventListener("pointerup", endDrag);
		track.addEventListener("pointercancel", endDrag);
	}

	const lightbox = document.getElementById("carrossel-lightbox");
	const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
	const lightboxClose = document.getElementById("lightbox-close");
	const lightboxPrev = document.getElementById("lightbox-prev");
	const lightboxNext = document.getElementById("lightbox-next");
	const triggers = Array.from(document.querySelectorAll<HTMLImageElement>("[data-lightbox-trigger]"));
	let currentIndex = 0;

	const showPhoto = (index: number) => {
		if (!lightboxImg || triggers.length === 0) return;
		currentIndex = (index + triggers.length) % triggers.length;
		lightboxImg.src = triggers[currentIndex].src;
	};

	const openLightbox = (index: number) => {
		if (!lightbox) return;
		showPhoto(index);
		lightbox.classList.add("is-open");
		lightbox.setAttribute("aria-hidden", "false");
	};

	const closeLightbox = () => {
		if (!lightbox) return;
		lightbox.classList.remove("is-open");
		lightbox.setAttribute("aria-hidden", "true");
	};

	triggers.forEach((img, i) => {
		img.addEventListener("click", () => {
			if (dragMoved) return;
			openLightbox(i);
		});
	});

	lightboxClose?.addEventListener("click", closeLightbox);
	lightboxPrev?.addEventListener("click", () => showPhoto(currentIndex - 1));
	lightboxNext?.addEventListener("click", () => showPhoto(currentIndex + 1));

	lightbox?.addEventListener("click", (e) => {
		if (e.target === lightbox) closeLightbox();
	});

	if (lightboxImg) {
		let touchStartX = 0;
		let touchDeltaX = 0;

		lightboxImg.addEventListener("touchstart", (e) => {
			touchStartX = e.touches[0].clientX;
			touchDeltaX = 0;
		});

		lightboxImg.addEventListener("touchmove", (e) => {
			touchDeltaX = e.touches[0].clientX - touchStartX;
		});

		lightboxImg.addEventListener("touchend", () => {
			if (touchDeltaX > 50) showPhoto(currentIndex - 1);
			else if (touchDeltaX < -50) showPhoto(currentIndex + 1);
		});
	}

	document.addEventListener("keydown", (e) => {
		if (!lightbox?.classList.contains("is-open")) return;
		if (e.key === "Escape") closeLightbox();
		if (e.key === "ArrowLeft") showPhoto(currentIndex - 1);
		if (e.key === "ArrowRight") showPhoto(currentIndex + 1);
	});

	gsap.fromTo(
		".carrossel__slide",
		{ opacity: 0, y: 30 },
		{
			opacity: 1,
			y: 0,
			duration: 0.7,
			stagger: 0.08,
			ease: "power3.out",
			scrollTrigger: {
				trigger: "#galeria",
				start: "top 80%",
			},
		}
	);
</script>
